---
// A page section with a top separator line and a heading.
// Content goes in the default slot.
interface Props {
  heading?: string;
  headingHtml?: string; // raw-HTML heading (e.g. two lines with <br>); wins over `heading`
  first?: boolean;   // omit the top separator line for the first section on a page
  centered?: boolean; // center-align text and center the content block
}
const { heading, headingHtml, first = false, centered = false } = Astro.props;
---
<section class:list={['py-12', !first && 'border-t border-current']}>
  <div class:list={['mx-auto max-w-4xl px-4', centered && 'text-center']}>
    {headingHtml ? (
      <h2 class="text-3xl sm:text-4xl font-bold mb-6" set:html={headingHtml} />
    ) : heading ? (
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">{heading}</h2>
    ) : null}
    <slot />
  </div>
</section>
