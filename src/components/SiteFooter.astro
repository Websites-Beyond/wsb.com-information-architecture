---
import { navLinks } from '../data/nav';
---
<footer class="border-t border-current mt-16">
  <div class="mx-auto max-w-4xl px-4 py-8 flex flex-wrap items-center justify-between gap-4 text-sm">
    <span class="opacity-70">Websites Beyond — wireframe</span>
    <nav class="flex flex-wrap gap-6">
      {navLinks.map((link) => (
        <a href={link.href} class="opacity-70 hover:opacity-100">{link.label}</a>
      ))}
    </nav>
  </div>
</footer>
